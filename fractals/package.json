{
  "name": "fractals",
  "version": "0.1.0",
  "description": "Utility-first IPTV client with multi-source merging and semantic search",
  "private": true,
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "electron-vite dev --mode web",
    "build": "electron-vite build",
    "build:electron": "pnpm build && electron-builder",
    "preview": "electron-vite preview",
    "lint": "eslint src electron --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-virtual": "^3.13.23",
    "any-ascii": "^0.3.3",
    "artplayer": "^5.4.0",
    "better-sqlite3": "^12.8.0",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "hls.js": "^1.6.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.31.10",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.3.1"
  },
  "build": {
    "appId": "tv.fractals.app",
    "productName": "Fractals",
    "directories": {
      "output": "dist-release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "resources/icons/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icons/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icons/icon.png"
    }
  }
}
