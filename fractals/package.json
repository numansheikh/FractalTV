{
  "name": "fractals",
  "version": "0.1.0",
  "description": "Utility-first IPTV client with multi-source merging and semantic search",
  "private": true,
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "electron-vite dev --mode web",
    "build": "electron-vite build",
    "build:electron": "pnpm build && electron-builder",
    "preview": "electron-vite preview",
    "lint": "eslint src electron --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.3.1"
  },
  "build": {
    "appId": "tv.fractals.app",
    "productName": "Fractals",
    "directories": {
      "output": "dist-release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.entertainment"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
